# Loopin CRM Environment Variables

# Supabase Database Connection
# Get these from your Supabase project settings -> API
DATABASE_URL=https://your-project.supabase.co
DATABASE_KEY=your-service-role-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# JWT Secret for authentication
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Asaas Payment Gateway
# Get these from https://www.asaas.com -> Configurações -> Integração
ASAAS_API_KEY=your-asaas-api-key
ASAAS_WEBHOOK_SECRET=your-webhook-secret

# Loopin.tv Integration (para sincronização bidirecional)
# URL do projeto Loopin.tv e Service Role Key
LOOPIN_TV_FUNCTIONS_URL=https://sxsmirhqbslmvyesikgg.supabase.co/functions/v1
LOOPIN_TV_SERVICE_ROLE_KEY=your-loopin-tv-service-role-key
ENABLE_LOOPIN_SYNC=true  # Desabilita sincronização se false
