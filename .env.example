# ====================================================================
# Loopin CRM — Variáveis de Ambiente
# Copie este arquivo para .env.local e preencha os valores
# ====================================================================

# ─── Supabase (Banco de Dados) ────────────────────────────────────────
DATABASE_URL=https://SEU_PROJECT_ID.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── JWT / Autenticação ───────────────────────────────────────────────
JWT_SECRET=loopin-crm-secret-change-in-production

# ─── Asaas (Gateway de Pagamentos) ───────────────────────────────────
ASAAS_API_KEY=$aact_COLE_SUA_CHAVE_AQUI
ASAAS_WEBHOOK_SECRET=cole_o_token_gerado_pelo_asaas

# ─── Integração Loopin.tv / Segurança ────────────────────────────────
# Usado para proteger a rota /api/clients/check-overdue chamada pelo cron-job
CRON_SECRET=um_segredo_qualquer

# (Opcional) Chave fornecida ao Loopin.tv para consultar rotas do CRM (/api/screens/report, etc)
CRM_API_KEY=chave-segura-api-crm

# URL base das edge functions do Loopin.tv
LOOPIN_TV_FUNCTIONS_URL=https://SEU_PROJECT_ID.supabase.co/functions/v1
LOOPIN_TV_SERVICE_ROLE_KEY=eyJhbGci...
