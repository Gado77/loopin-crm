# ====================================================================
# Loopin CRM — Variáveis de Ambiente
# Copie este arquivo para .env.local e preencha os valores
# ====================================================================

# ─── Supabase (Banco de Dados) ────────────────────────────────────────
# URL do projeto CRM no Supabase
DATABASE_URL=https://SEU_PROJECT_ID.supabase.co

# Service Role Key do projeto CRM (NÃO exponha no frontend!)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── JWT / Autenticação ───────────────────────────────────────────────
# Secret para geração de tokens JWT de sessão (mude em produção!)
JWT_SECRET=loopin-crm-secret-change-in-production

# ─── Asaas (Gateway de Pagamentos) ───────────────────────────────────
# Chave de API do Asaas
# Sandbox: https://sandbox.asaas.com → Configurações → Integrações → API
# Produção: https://www.asaas.com → Configurações → Integrações → API
# Formato: $aact_XXX... (produção) ou $aact_sandbox_XXX... (sandbox)
ASAAS_API_KEY=$aact_COLE_SUA_CHAVE_AQUI

# Secret gerado ao configurar o Webhook no painel Asaas
# Asaas → Configurações → Integrações → Webhooks → (criar) → copiar token
ASAAS_WEBHOOK_SECRET=cole_o_token_gerado_pelo_asaas
